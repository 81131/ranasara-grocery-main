# /.env.example
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_db_password
POSTGRES_DB=grocery_management

# We construct the URL using the variables above
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

ADMIN_FIRSTNAME=market
ADMIN_LASTNAME=admin
ADMIN_PASSWORD=your_secure_admin_password
ADMIN_EMAIL=admin@ranasara.com

# JWT Secret
JWT_SECRET_KEY=your_64_character_secure_random_string_here

# API Keys
VITE_GOOGLE_AUTH_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_AUTH_CLIENT_SECRET=your_google_client_secret
GEMINI_API_KEY=your_gemini_api_key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
